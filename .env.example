# ID numérico da sua conta Instagram Business
IG_USER_ID=

# Long-lived access token (~60 dias). Renove com scripts/refresh_token.py
IG_ACCESS_TOKEN=

# Base pública das fotos. Se usar o próprio repo no GitHub:
# https://raw.githubusercontent.com/SEU_USER/SEU_REPO/main/photos
PUBLIC_BASE_URL=

# Opcionais (default ok)
GRAPH_VERSION=v21.0
GRAPH_HOST=https://graph.facebook.com

# Só necessários para scripts/refresh_token.py (Facebook Login)
FB_APP_ID=
FB_APP_SECRET=
