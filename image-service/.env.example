# --- Supabase (service role; só no backend) — usado a partir da Fase B ---
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
STORAGE_BUCKET=media

# --- Segredo compartilhado com o painel (Next) — MESMO valor nos dois ---
# Gere com: python -c "import secrets; print(secrets.token_urlsafe(32))"
SERVICE_SHARED_SECRET=

# --- Instagram OAuth / API (Fase C+) ---
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
GRAPH_HOST=https://graph.instagram.com
GRAPH_VERSION=v21.0

# --- Cifragem dos tokens guardados (Fase C+) ---
# Gere com: python -c "import secrets; print(secrets.token_urlsafe(32))"
TOKEN_ENC_KEY=

# --- CORS: origem do painel ---
WEB_ORIGIN=http://localhost:3000
